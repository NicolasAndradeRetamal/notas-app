# Cadena de conexión a PostgreSQL. El puerto 5433 es el publicado por
# docker-compose.yml (el 5432 lo ocupa otro proyecto del portafolio en local).
DATABASE_URL="postgresql://notas:notas@localhost:5433/notas_app?schema=public"

# Clave de firma del JWT de sesión (32+ bytes aleatorios). Generarla con:
#   openssl rand -base64 32
# o, si no tienes openssl a mano:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-de-32-bytes"

# Necesario detrás de un proxy inverso o dentro de un contenedor.
AUTH_TRUST_HOST="true"

# URL pública de la aplicación. Opcional en local (Auth.js la infiere de la
# petición); recomendado fijarla en producción.
# AUTH_URL="https://tu-dominio.example"

# --- Fase 2 (IA): no se usan todavía, se documentan para cuando se implemente ---
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# AI_SUMMARY_MODEL="claude-haiku-4-5"
# AI_CHAT_MODEL="claude-sonnet-4-5"
# AI_DAILY_TOKEN_BUDGET="100000"
